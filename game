import java.util.Random;

public class Person {
    private int x, y;
    private String image = "Pp";
    private int live = 3;
    Random r = new Random();

    Person(int sizeBoard) {
        this.y = sizeBoard;
        this.x = 1 + r.nextInt(sizeBoard - 1);
    }

    Person(int x, int y) {
        this.x = x;
        this.y = y;
    }

    Person() {
        this(1, 1);
    }

    public int getX() {
        return x;
    }

    public int getY() {
        return y;
    }

    public int getLive() {
        return live;
    }

    public String getImage() {
        return image;
    }

    public boolean moveCorrect(int x, int y) {
        return (this.x == x && Math.abs(this.y - y) == 1) ||
                (this.y == y && Math.abs(this.x - x) == 1);
    }

    void move(int x, int y) {
        this.x = x;
        this.y = y;
    }

    public void downLive() {
        live--;
    }
}




